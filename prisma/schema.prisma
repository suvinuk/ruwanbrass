// Prisma Schema for Ruwan Brass Enterprise Distribution Operating System (EDOS)
// Database: PostgreSQL ready (Multi-tenant optimized)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-name"
}

enum Role {
  SUPER_ADMIN
  CEO
  FINANCE_MANAGER
  SALES_MANAGER
  WAREHOUSE_MANAGER
  HR_MANAGER
  SALES_PERSON
  DELIVERY_DRIVER
  SUPPLIER_ADMIN
  DISTRIBUTOR_PARTNER
  RETAIL_CUSTOMER
  AUDITOR
  AI_AGENT
}

enum OrderStatus {
  DRAFT
  APPROVED
  PACKED
  SHIPPED
  DELIVERED
  PAID
  CANCELLED
  RETURNED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  name          String
  passwordHash  String
  role          Role        @default(SALES_PERSON)
  avatarUrl     String?
  phone         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relationships
  managedOrders  Order[]          @relation("SalesPersonOrders")
  driverDeliveries Delivery[]     @relation("DriverDeliveries")
  payouts        CommissionPayout[]
  auditLogs      AuditLog[]
  visitLogs      CustomerVisit[]
}

model Customer {
  id                String    @id @default(uuid())
  businessName      String
  contactName       String
  email             String    @unique
  phone             String
  address           String
  gpsLatitude       Float?
  gpsLongitude      Float?
  creditLimit       Decimal   @default(0.00)
  currentBalance    Decimal   @default(0.00)
  riskScore         Float     @default(0.0) // AI calculated (0 to 100)
  loyaltyScore      Int       @default(0)
  churnProbability  Float     @default(0.0) // AI predicted
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders            Order[]
  visits            CustomerVisit[]
  invoices          Invoice[]
}

model Supplier {
  id                String           @id @default(uuid())
  companyName       String
  contactName       String
  email             String           @unique
  phone             String
  rating            Float            @default(5.0) // Supplier reliability score (0-5)
  creditLimit       Decimal          @default(0.00)
  outstandingCredit Decimal          @default(0.00)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  inventoryItems    InventoryItem[]
}

model Warehouse {
  id          String           @id @default(uuid())
  name        String
  location    String
  capacityCbm Float?
  stockLines  WarehouseStock[]
}

model InventoryItem {
  id              String           @id @default(uuid())
  sku             String           @unique
  name            String
  description     String?
  category        String
  wholesalePrice  Decimal
  retailPrice     Decimal
  creditPrice     Decimal
  minStockAlert   Int              @default(10)
  supplierId      String?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  stocks          WarehouseStock[]
  orderItems      OrderItem[]
}

model WarehouseStock {
  id          String        @id @default(uuid())
  warehouseId String
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Int           @default(0)
  binLocation String?       // Bin Location mapping for fast picking

  @@unique([warehouseId, itemId])
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  salesPersonId String
  salesPerson   User        @relation("SalesPersonOrders", fields: [salesPersonId], references: [id])
  status        OrderStatus @default(DRAFT)
  totalAmount   Decimal
  discountTotal Decimal     @default(0.00)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]
  deliveries    Delivery[]
  invoices      Invoice[]
}

model OrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id])
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Int
  unitPrice   Decimal
  discountVal Decimal       @default(0.00)
}

model Delivery {
  id                String         @id @default(uuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id])
  driverId          String
  driver            User           @relation("DriverDeliveries", fields: [driverId], references: [id])
  status            DeliveryStatus @default(PENDING)
  gpsRouteJson      String?        // Optimized route payload
  proofSignatureUrl String?
  proofOtp          String?
  proofPhotoUrl     String?
  fuelUsageLiters   Float?
  deliveryTime      DateTime?
  createdAt         DateTime       @default(now())
}

model Invoice {
  id             String    @id @default(uuid())
  invoiceNumber  String    @unique
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  dueDate        DateTime
  amountDue      Decimal
  amountPaid     Decimal   @default(0.00)
  pdfUrl         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CommissionPayout {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Decimal
  periodStart DateTime
  periodEnd   DateTime
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CustomerVisit {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  salesPersonId String
  salesPerson   User     @relation(fields: [salesPersonId], references: [id])
  notes         String?
  checkInLat    Float?
  checkInLng    Float?
  visitTime     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model RiskAlert {
  id        String   @id @default(uuid())
  type      String   // CREDIT, DEFAULTER, STOCK_OUT, DELAY
  message   String
  severity  String   // INFO, WARNING, CRITICAL
  isCleared Boolean  @default(false)
  createdAt DateTime @default(now())
}
